<!-- GSAP + ScrollTrigger -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>

<script is:inline>
function initFeaturesAnimations() {
  // Asegurarnos de que GSAP esté disponible
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

  gsap.registerPlugin(ScrollTrigger);
  
  // ¡Vital para Astro! Limpiar los triggers fantasmas de la página anterior
  ScrollTrigger.getAll().forEach(t => t.kill());

  /* ─── Perspectiva global ─── */
  gsap.set('#featCardsContainer', { perspective: 1200 });

  const cards = gsap.utils.toArray('.feat-scroll-card');
  cards.forEach(function(card, i) {
    const widgets = card.querySelectorAll('.feat-card-widget');

    /* ── Estado inicial: texto con y-offset, widgets solo opacity ── */
    const textCols = card.querySelector('.feat-card-text');
    if (textCols) {
      const nodes = textCols.querySelectorAll('.feat-card-child');
      gsap.set(nodes, { opacity: 0, y: 16 });
    }
    gsap.set(widgets, { opacity: 0, y: 0 });

    /* ── Timeline de entrada de la card ── */
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: card,
        start: 'top 82%',
        end: 'top 30%',
        toggleActions: 'play none none none',
      }
    });

    /* 1. La card entra con efecto 3D + muelle */
    const isMobile = window.innerWidth < 768;
    tl.fromTo(card,
      { opacity: 0, y: isMobile ? 0 : 90, rotationX: isMobile ? 0 : 14, scale: 0.96, transformOrigin: 'center top' },
      { opacity: 1, y: 0, rotationX: 0, scale: 1, duration: 1.1, ease: 'expo.out' }
    );

    /* 2. Hijos de texto en stagger con y */
    const textChildNodes = textCols ? textCols.querySelectorAll('.feat-card-child') : [];
    if (textChildNodes.length) {
      tl.to(textChildNodes,
        { opacity: 1, y: 0, duration: 0.65, ease: 'power3.out', stagger: 0.11 },
        '-=0.65'
      );
    }

    /* 3. Widgets: solo fade, sin y — aparecen cuando termina el texto */
    tl.to(widgets, { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.3');
  });
}

// MAGIA DE ASTRO: Ejecutar al cargar la página por primera vez y al navegar entre páginas
document.addEventListener('astro:page-load', initFeaturesAnimations);
// Fallback de seguridad
document.addEventListener('DOMContentLoaded', initFeaturesAnimations);
</script>