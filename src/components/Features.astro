<style>
  /* ── Las cards empiezan ocultas (GSAP las animará) ── */
  .feat-scroll-card {
    opacity: 0;
    will-change: transform, opacity;
  }

  /* ── En desktop, overflow clip para efectos 3D ── */
  @media (min-width: 768px) {
    .feat-scroll-card {
      overflow: clip;
    }
  }
  
  /* ── En móvil, overflow hidden y spacing optimizado ── */
  @media (max-width: 767px) {
    .feat-scroll-card {
      overflow: hidden;
      /* Asegurar espacio interno suficiente */
      padding-top: 1.25rem !important;
      padding-bottom: 1.75rem !important;
    }
    
    /* Espaciado entre elementos en móvil */
    .feat-card-text {
      margin-bottom: 1.5rem;
    }
    
    /* Los widgets necesitan espacio para respirar */
    .feat-card-widget {
      margin-bottom: 0.5rem;
    }
  }

  /* ── Los hijos animables también ocultos ── */
  .feat-card-child {
    opacity: 0;
    isolation: isolate;
  }

  /* ── Columna de texto dentro de la card: siempre sobre el widget ── */
  .feat-scroll-card > .feat-card-text {
    position: relative;
    z-index: 2;
    isolation: isolate;
  }
  .feat-scroll-card > .feat-card-widget {
    position: relative;
    z-index: 1;
  }

  /* ── Número stat ── */
  .stat-value {
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
  }

  /* ── Barra ocupación (sin animación) ── */
  .ocupacion-bar { width: 75%; }

  /* ── Checkmark RGPD (visible desde el inicio) ── */
  .shield-check {
    stroke-dasharray: 52;
    stroke-dashoffset: 0;
  }
</style>

