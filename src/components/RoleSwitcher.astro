---
---

<section class="py-24 md:py-32 px-4 sm:px-6 w-full font-sans overflow-hidden">
  <div class="max-w-6xl mx-auto relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
        <h2 class="text-4xl md:text-5xl font-sans font-extrabold tracking-tight text-[#2D3748] mb-6">
            Una app, dos mundos.
        </h2>
        <p class="text-xl md:text-2xl text-slate-600 font-medium tracking-tight">
            Mindesk se adapta a quien lo usa. <br class="hidden sm:block" /> Cambia el interruptor para ver la diferencia.
        </p>
    </div>

    <div class="relative rounded-[2.5rem] bg-linear-to-br from-white/40 to-white/5 backdrop-blur-2xl border border-white/60 shadow-[inset_0_1px_0_rgba(255,255,255,0.8),0_20px_50px_rgba(0,0,0,0.05)] overflow-hidden" id="appSimulator">
      
      <div class="flex items-center justify-center px-6 py-4 border-b border-white/40 bg-white/20">
        
        <div class="relative bg-white/40 backdrop-blur-md border border-white/60 p-1.5 rounded-full flex items-center cursor-pointer shadow-inner" id="roleToggle">
            <div class="absolute left-1.5 w-36 h-10 bg-white rounded-full shadow-md transition-transform duration-500 ease-out" id="toggleBg"></div>
            
            <button class="relative z-10 w-36 py-2 text-sm font-extrabold text-[#10b981] transition-colors duration-300 text-center focus:outline-none tracking-wide" onclick="setRole('manager')" id="btnManager">
                Vista Gerente
            </button>
            
            <button class="relative z-10 w-36 py-2 text-sm font-extrabold text-slate-500 hover:text-slate-700 transition-colors duration-300 text-center focus:outline-none tracking-wide" onclick="setRole('pro')" id="btnPro">
                Vista Terapeuta
            </button>
        </div>

      </div>

      <div class="grid px-6 py-16 md:px-16 md:py-24">
        
        <div id="contentManager" class="col-start-1 row-start-1 transition-all duration-700 opacity-100 z-10 translate-y-0">
            <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
                
                <div class="flex flex-col order-1 md:order-0">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#10b981]/10 text-[#10b981] text-xs font-bold tracking-wide uppercase mb-6 w-max border border-[#10b981]/20 shadow-sm">
                        Para la Dirección
                    </div>
                    <h3 class="text-3xl md:text-5xl font-extrabold text-[#2D3748] leading-[1.1] mb-6 tracking-tight">
                        Control total de<br/>tu negocio.
                    </h3>
                    <p class="text-slate-700 font-medium leading-relaxed text-lg mb-8">
                        Como gerente, tu dashboard te muestra la salud financiera y el rendimiento del equipo en tiempo real. Decisiones basadas en datos, no en intuición.
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-3 text-slate-700 font-medium">
                            <span class="w-6 h-6 rounded-full bg-[#10b981]/10 flex items-center justify-center text-sm shrink-0 border border-[#10b981]/20 text-[#10b981]">✓</span>
                            Facturación global y pagos pendientes
                        </li>
                        <li class="flex items-center gap-3 text-slate-700 font-medium">
                            <span class="w-6 h-6 rounded-full bg-[#10b981]/10 flex items-center justify-center text-sm shrink-0 border border-[#10b981]/20 text-[#10b981]">✓</span>
                            Rendimiento por terapeuta
                        </li>
                    </ul>
                </div>

                <div class="relative group order-2 md:order-0 w-full max-w-md mx-auto md:max-w-none">
                    <div class="absolute inset-0 bg-[#10b981]/20 blur-[80px] rounded-full opacity-60 group-hover:opacity-100 transition-opacity duration-700 z-0"></div>
                    
                    <div class="relative z-10 bg-white/80 backdrop-blur-xl p-6 md:p-8 rounded-4xl shadow-xl border border-white group-hover:-translate-y-2 transition-transform duration-500">
                        <div class="flex justify-between items-start mb-6">
                            <div>
                                <div class="text-[11px] text-slate-400 uppercase tracking-widest font-extrabold mb-1">Ingresos del Mes</div>
                                <div class="text-4xl font-extrabold text-[#2D3748] tracking-tighter">12.450<span class="text-2xl text-slate-400 font-bold">€</span></div>
                            </div>
                            <div class="flex items-center gap-1 text-[#10b981] bg-[#10b981]/10 px-2.5 py-1 rounded-lg text-sm font-bold border border-[#10b981]/20">
                                ↑ 14.5%
                            </div>
                        </div>
                        
                        <div class="relative h-36 mt-8 flex items-end gap-3 md:gap-4 z-10 border-b border-slate-200/60 pb-1">
                            <div class="absolute inset-0 flex flex-col justify-between pb-1 pointer-events-none">
                                <div class="border-t border-slate-200 border-dashed w-full h-px opacity-50"></div>
                                <div class="border-t border-slate-200 border-dashed w-full h-px opacity-50"></div>
                                <div class="border-t border-slate-200 border-dashed w-full h-px opacity-50"></div>
                            </div>
                            <div class="relative w-1/5 bg-slate-200/60 rounded-t-xl h-[40%] transition-all duration-500 hover:bg-slate-300/60 cursor-pointer"></div>
                            <div class="relative w-1/5 bg-slate-200/60 rounded-t-xl h-[65%] transition-all duration-500 hover:bg-slate-300/60 cursor-pointer"></div>
                            <div class="relative w-1/5 bg-slate-200/60 rounded-t-xl h-[50%] transition-all duration-500 hover:bg-slate-300/60 cursor-pointer"></div>
                            <div class="relative w-1/5 bg-linear-to-t from-[#10b981] to-[#34d399] rounded-t-xl h-[90%] shadow-[0_0_20px_rgba(16,185,129,0.4)] group-hover:scale-y-105 origin-bottom transition-all duration-500 cursor-pointer z-10">
                                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-[#2D3748] text-white text-[10px] font-bold py-1 px-2.5 rounded-md shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300">Hoy</div>
                            </div>
                            <div class="relative w-1/5 bg-slate-200/60 rounded-t-xl h-[30%] transition-all duration-500 hover:bg-slate-300/60 cursor-pointer"></div>
                        </div>
                    </div>

                    <div class="absolute -bottom-6 -left-6 md:-left-10 bg-white/90 backdrop-blur-md p-4 rounded-2xl border border-white shadow-xl z-20 flex gap-4 items-center transition-transform duration-700 group-hover:translate-x-2 group-hover:-translate-y-2">
                        <div class="w-12 h-12 rounded-full bg-[#10b981]/10 flex items-center justify-center text-xl border border-[#10b981]/20">📈</div>
                        <div>
                            <div class="text-[10px] text-slate-400 font-extrabold uppercase tracking-widest">Rentabilidad</div>
                            <div class="text-base font-extrabold text-[#2D3748]">Óptima</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="contentPro" class="col-start-1 row-start-1 transition-all duration-700 opacity-0 pointer-events-none z-0 translate-y-8">
            <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
                
                <div class="flex flex-col order-1 md:order-0">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 text-indigo-600 text-xs font-bold tracking-wide uppercase mb-6 w-max border border-indigo-500/20 shadow-sm">
                        Para el Especialista
                    </div>
                    <h3 class="text-3xl md:text-5xl font-extrabold text-[#2D3748] leading-[1.1] mb-6 tracking-tight">
                        Foco absoluto en<br/>tu paciente.
                    </h3>
                    <p class="text-slate-700 font-medium leading-relaxed text-lg mb-8">
                        El ruido administrativo desaparece. Tu vista se centra exclusivamente en tu agenda, las evoluciones clínicas y la terapia.
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-3 text-slate-700 font-medium">
                            <span class="w-6 h-6 rounded-full bg-indigo-50 flex items-center justify-center text-sm shrink-0 border border-indigo-100 text-indigo-500">✓</span>
                            Redacción rápida de informes y notas
                        </li>
                        <li class="flex items-center gap-3 text-slate-700 font-medium">
                            <span class="w-6 h-6 rounded-full bg-indigo-50 flex items-center justify-center text-sm shrink-0 border border-indigo-100 text-indigo-500">✓</span>
                            Privacidad estricta con un clic
                        </li>
                    </ul>
                </div>

                <div class="relative group order-2 md:order-0 w-full max-w-md mx-auto md:max-w-none">
                    <div class="absolute inset-0 bg-indigo-500/15 blur-[80px] rounded-full opacity-60 group-hover:opacity-100 transition-opacity duration-700 z-0"></div>
                    
                    <div class="relative z-10 bg-white/80 backdrop-blur-xl p-6 md:p-8 rounded-4xl shadow-xl border border-white group-hover:-translate-y-2 transition-transform duration-500">
                        
                        <div class="flex items-start gap-4 mb-6 border-b border-slate-200/60 pb-5">
                            <div class="relative w-14 h-14 rounded-2xl bg-linear-to-br from-indigo-50 to-indigo-100 border border-indigo-200 shadow-inner flex items-center justify-center text-2xl z-10 shrink-0">
                                👩‍🦰
                                <div class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-[#10b981] border-2 border-white rounded-full"></div>
                            </div>
                            <div>
                                <h4 class="text-xl font-extrabold text-[#2D3748] tracking-tight">Ana García</h4>
                                <div class="flex flex-wrap gap-2 mt-2">
                                    <span class="bg-indigo-50 border border-indigo-100 text-indigo-600 text-[10px] px-2.5 py-0.5 rounded-full font-bold uppercase tracking-wide">Ansiedad</span>
                                    <span class="bg-slate-100 border border-slate-200 text-slate-500 text-[10px] px-2.5 py-0.5 rounded-full font-bold uppercase tracking-wide">Sesión #4</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="bg-slate-50/80 rounded-xl p-4 md:p-5 border border-slate-100 mb-6 group-hover:bg-white transition-colors duration-300">
                            <div class="flex gap-2 mb-3 items-center">
                                <div class="w-2.5 h-2.5 rounded-full bg-indigo-300"></div>
                                <div class="h-2 w-1/3 bg-slate-300 rounded"></div>
                            </div>
                            <div class="space-y-2.5">
                                <div class="h-2 w-full bg-indigo-100 rounded"></div>
                                <div class="h-2 w-5/6 bg-indigo-100 rounded"></div>
                                <div class="h-2 w-4/6 bg-indigo-100 rounded"></div>
                            </div>
                        </div>
                        
                        <button class="w-full py-4 bg-indigo-600 text-white rounded-xl text-sm font-bold shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:-translate-y-0.5 transition-all duration-300 tracking-wide">
                            Guardar evolución clínica
                        </button>
                    </div>

                    <div class="absolute -top-6 -right-6 md:-right-10 bg-white/90 backdrop-blur-md p-3.5 rounded-2xl border border-white shadow-xl z-20 flex gap-3 items-center transition-transform duration-700 rotate-3 group-hover:rotate-0 group-hover:-translate-y-1">
                        <div class="w-10 h-10 rounded-full bg-orange-50 flex items-center justify-center text-lg border border-orange-100">
                            🗓️
                        </div>
                        <div class="pr-2">
                            <div class="text-[9px] text-slate-400 font-extrabold uppercase tracking-widest">Siguiente</div>
                            <div class="text-sm font-extrabold text-[#2D3748]">Mañana, 10:00</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
  function setRole(role) {
    const toggleBg = document.getElementById('toggleBg');
    const btnManager = document.getElementById('btnManager');
    const btnPro = document.getElementById('btnPro');
    
    const contentManager = document.getElementById('contentManager');
    const contentPro = document.getElementById('contentPro');

    if (role === 'manager') {
        // Mover la pastilla a la izquierda
        toggleBg.style.transform = 'translateX(0)';
        
        // Estilos botones (Gerente se ilumina en Verde)
        btnManager.classList.add('text-[#10b981]');
        btnManager.classList.remove('text-slate-500');
        btnPro.classList.remove('text-indigo-600');
        btnPro.classList.add('text-slate-500');

        // Transición de contenido (Ocultar Terapeuta, Mostrar Gerente)
        contentPro.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
        contentPro.classList.add('opacity-0', 'pointer-events-none', 'translate-y-8');
        
        contentManager.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-8');
        contentManager.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
        
    } else {
        // Mover la pastilla a la derecha
        toggleBg.style.transform = 'translateX(100%)';
        
        // Estilos botones (Terapeuta se ilumina en Morado)
        btnManager.classList.remove('text-[#10b981]');
        btnManager.classList.add('text-slate-500');
        btnPro.classList.add('text-indigo-600');
        btnPro.classList.remove('text-slate-500');

        // Transición de contenido (Ocultar Gerente, Mostrar Terapeuta)
        contentManager.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
        contentManager.classList.add('opacity-0', 'pointer-events-none', 'translate-y-8');
        
        contentPro.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-8');
        contentPro.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
    }
  }
</script>