<script is:inline>
  function setRole(role) {
    const toggleBg = document.getElementById("toggleBg");
    const btnManager = document.getElementById("btnManager");
    const btnPro = document.getElementById("btnPro");
    const cManager = document.getElementById("contentManager");
    const cPro = document.getElementById("contentPro");
    const tint = document.getElementById("tintOverlay");
    const simulator = document.getElementById("appSimulator");
    const progressFill = document.getElementById("progressFill");

    if (role === "manager") {
      toggleBg.style.transform = "translateX(0)";

      btnManager.classList.remove("text-slate-400");
      btnManager.classList.add("text-[#10b981]");
      btnPro.classList.remove("text-[#b788f4]");
      btnPro.classList.add("text-slate-400");

      tint.classList.remove("tint-pro");
      tint.classList.add("tint-manager");
      simulator.style.boxShadow =
        "inset 0 1px 0 rgba(255,255,255,0.8), 0 20px 50px rgba(16,185,129,0.07)";

      cPro.classList.remove(
        "opacity-100",
        "pointer-events-auto",
        "translate-y-0",
      );
      cPro.classList.add("opacity-0", "pointer-events-none", "translate-y-8");
      cManager.classList.remove(
        "opacity-0",
        "pointer-events-none",
        "translate-y-8",
      );
      cManager.classList.add(
        "opacity-100",
        "pointer-events-auto",
        "translate-y-0",
      );
    } else {
      toggleBg.style.transform = "translateX(100%)";

      btnPro.classList.remove("text-slate-400");
      btnPro.classList.add("text-[#b788f4]");
      btnManager.classList.remove("text-[#10b981]");
      btnManager.classList.add("text-slate-400");

      tint.classList.remove("tint-manager");
      tint.classList.add("tint-pro");
      simulator.style.boxShadow =
        "inset 0 1px 0 rgba(255,255,255,0.8), 0 20px 50px rgba(183,136,244,0.08)";

      cManager.classList.remove(
        "opacity-100",
        "pointer-events-auto",
        "translate-y-0",
      );
      cManager.classList.add(
        "opacity-0",
        "pointer-events-none",
        "translate-y-8",
      );
      cPro.classList.remove(
        "opacity-0",
        "pointer-events-none",
        "translate-y-8",
      );
      cPro.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");

      // Animar barra de progreso
      if (progressFill) {
        progressFill.classList.remove("animate");
        void progressFill.offsetWidth; // reflow
        setTimeout(() => progressFill.classList.add("animate"), 60);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", function () {
    const toggleBg = document.getElementById("toggleBg");
    if (toggleBg) toggleBg.style.transform = "translateX(0)";
  });
</script>
