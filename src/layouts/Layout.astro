---
// src/layouts/Layout.astro
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-sans/700.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
    title: string;
    description?: string;
    canonical?: string;
    ogImage?: string;
    ogType?: string;
    noindex?: boolean;
}

const {
    title,
    description = "Mindesk: software de gestión clínica para psicólogos, logopedas y pedagogos. Organiza tu gabinete, simplifica tu día.",
    canonical,
    ogImage = "/og-default.png",
    ogType = "website",
    noindex = false,
} = Astro.props;

const canonicalURL = canonical
    ? new URL(canonical, Astro.site)
    : new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <!-- SEO Core -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL.href} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}

        <!-- DNS prefetch for external origins (lightweight, no penalty) -->
        <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
        <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- Preload LCP hero background -->
        <link
            rel="preload"
            href="/fondo-hero.webp"
            as="image"
            type="image/webp"
        />

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
        <meta property="og:type" content={ogType} />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:site_name" content="Mindesk" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta
            name="twitter:image"
            content={new URL(ogImage, Astro.site).href}
        />

        <!-- GEO Tags -->
        <meta name="geo.region" content="ES-AN" />
        <meta name="geo.placename" content="Dos Hermanas, Sevilla" />

        <!-- Additional Meta -->
        <meta name="author" content="Mindesk" />
        <meta name="theme-color" content="#10b981" />

        <!-- Per-page head slot (JSON-LD, extra meta, etc.) -->
        <slot name="head" />

        <ClientRouter />
    </head>

    <body
        class="text-slate-900 font-sans antialiased overflow-x-hidden min-h-screen flex flex-col relative"
    >
        <div
            class="fixed inset-0 z-[-1] bg-cover bg-center bg-no-repeat"
            style="background-image: url('fondo-hero.webp');"
        >
            <div class="absolute inset-0 bg-white/60 pointer-events-none"></div>
        </div>

        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-100 bg-brand-primary text-white px-4 py-2 rounded-md font-bold focus:outline-none focus:ring-4 focus:ring-brand-primary/30"
        >
            Saltar al contenido principal
        </a>

        <nav
            class="fixed top-6 left-1/2 -translate-x-1/2 w-[95%] max-w-5xl flex justify-between items-center px-6 py-3 backdrop-blur-md z-50 border border-white/60 bg-white/60 shadow-lg shadow-slate-200/20 rounded-full"
            aria-label="Navegación principal"
        >
            <a
                href="/"
                class="flex items-center hover:scale-105 transition-transform duration-300 z-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#10b981] rounded-md p-1"
                aria-label="Inicio de Mindesk"
            >
                <img
                    src="/logo.webp"
                    alt="Logo de Mindesk"
                    class="h-12 md:h-13 w-auto object-contain"
                    width="150"
                    height="48"
                />
            </a>

            <div
                class="hidden md:flex items-center gap-8 text-sm font-bold tracking-wide text-slate-700 font-sans"
            >
                <a
                    href="/como-funciona"
                    class="hover:text-[#10b981] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#10b981] rounded-md px-2 py-1"
                    >Cómo funciona</a
                >
                <a
                    href="/contacto"
                    class="hover:text-[#10b981] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#10b981] rounded-md px-2 py-1"
                    >Contacto</a
                >
                <a
                    href="/contacto"
                    class="ml-2 px-7 py-2.5 bg-[#10b981] rounded-full text-white font-bold text-sm hover:scale-105 transition-all shadow-[0_0_20px_rgba(16,185,129,0.35)] hover:shadow-[0_0_35px_rgba(16,185,129,0.5)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#10b981] focus-visible:ring-offset-2"
                >
                    Solicitar Acceso Beta
                </a>
            </div>

            <button
                id="menu-btn"
                aria-expanded="false"
                aria-controls="mobile-menu"
                aria-label="Abrir menú de navegación"
                class="md:hidden text-slate-900 p-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#10b981] rounded-full z-50"
            >
                <svg
                    id="icon-open"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-7 h-7 transition-transform duration-300"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
                </svg>
                <svg
                    id="icon-close"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-7 h-7 hidden transition-transform duration-300 rotate-90"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <div
                id="mobile-menu"
                class="absolute top-[120%] left-0 w-full rounded-3xl bg-white/95 backdrop-blur-xl shadow-2xl flex flex-col items-center py-8 gap-6 origin-top transition-all duration-300 ease-in-out opacity-0 invisible -translate-y-2 pointer-events-none border border-slate-100"
            >
                <a
                    href="/como-funciona"
                    class="text-lg font-sans font-bold text-slate-800 hover:text-[#10b981] transition-colors mobile-link"
                    >Cómo Funciona</a
                >
                <a
                    href="/contacto"
                    class="text-lg font-sans font-bold text-slate-800 hover:text-[#10b981] transition-colors mobile-link"
                    >Contacto</a
                >
                <a
                    href="#"
                    class="text-lg font-sans font-bold text-slate-800 hover:text-[#10b981] transition-colors mobile-link"
                    >Login</a
                >
                <a
                    href="/contacto"
                    class="mt-2 px-8 py-3 bg-[#10b981] rounded-full text-white font-bold text-base shadow-[0_0_20px_rgba(16,185,129,0.4)] mobile-link"
                    >Solicitar Acceso Beta</a
                >
            </div>
        </nav>

        <main id="main-content" class="relative z-10 flex-1">
            <slot />
        </main>

        <Footer />

        <script>
            document.addEventListener("astro:page-load", () => {
                const btn = document.getElementById("menu-btn");
                const menu = document.getElementById("mobile-menu");
                const iconOpen = document.getElementById("icon-open");
                const iconClose = document.getElementById("icon-close");
                const links = document.querySelectorAll(".mobile-link");

                function toggleMenu() {
                    if (menu && iconOpen && iconClose && btn) {
                        const isClosed = menu.classList.contains("invisible");

                        // Actualizar ARIA
                        btn.setAttribute("aria-expanded", String(isClosed));

                        if (isClosed) {
                            menu.classList.remove(
                                "invisible",
                                "opacity-0",
                                "-translate-y-5",
                                "pointer-events-none",
                            );
                            iconOpen.classList.add("hidden");
                            iconClose.classList.remove("hidden", "rotate-90");
                        } else {
                            menu.classList.add(
                                "invisible",
                                "opacity-0",
                                "-translate-y-5",
                                "pointer-events-none",
                            );
                            iconOpen.classList.remove("hidden");
                            iconClose.classList.add("hidden", "rotate-90");
                        }
                    }
                }

                if (btn) btn.addEventListener("click", toggleMenu);

                links.forEach((link) => {
                    link.addEventListener("click", () => {
                        if (menu && iconOpen && iconClose && btn) {
                            menu.classList.add(
                                "invisible",
                                "opacity-0",
                                "-translate-y-5",
                                "pointer-events-none",
                            );
                            iconOpen.classList.remove("hidden");
                            iconClose.classList.add("hidden");
                            btn.setAttribute("aria-expanded", "false");
                        }
                    });
                });
            });
        </script>
        <CookieBanner />
    </body>
</html>
