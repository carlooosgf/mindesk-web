---
import Layout from "../layouts/Layout.astro";

const seoTitle =
    "Cómo Funciona la Beta | Mindesk - Software de Gestión Clínica";
const seoDescription =
    "Descubre cómo funciona el programa Beta de Mindesk: visita personalizada a tu gabinete, entorno sandbox con datos ficticios y feedback directo con los fundadores. Co-crea el software de gestión clínica perfecto para tu consulta.";

const jsonLd = [
    {
        "@context": "https://schema.org",
        "@type": "HowTo",
        name: "Cómo participar en la Beta de Mindesk",
        description: seoDescription,
        step: [
            {
                "@type": "HowToStep",
                position: 1,
                name: "Nos conocemos",
                text: "Nos acercamos a tu gabinete para explicarte el proyecto en persona. Queremos conocer tus frustraciones con tu sistema actual y ver cómo trabajas.",
            },
            {
                "@type": "HowToStep",
                position: 2,
                name: "Tu propio Lab",
                text: "Te creamos una cuenta y la cargamos con datos de prueba. Un entorno seguro (Sandbox) para que experimentes, simules sesiones y pulses botones sin miedo a romper nada.",
            },
            {
                "@type": "HowToStep",
                position: 3,
                name: "Pide y se te dará",
                text: "Tu misión no es trabajar, es criticar. ¿Falta un botón? ¿Te sobra un menú? Nos lo cuentas a través de una línea directa y nosotros lo construimos.",
            },
        ],
    },
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
            {
                "@type": "ListItem",
                position: 1,
                name: "Inicio",
                item: "https://www.mindesk.es/",
            },
            {
                "@type": "ListItem",
                position: 2,
                name: "Cómo funciona",
                item: "https://www.mindesk.es/como-funciona/",
            },
        ],
    },
];
---

<Layout title={seoTitle} description={seoDescription}>
    <Fragment slot="head">
        {
            jsonLd.map((schema) => (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(schema)}
                />
            ))
        }
    </Fragment>

    <section
        class="relative pt-32 md:pt-40 pb-16 md:pb-24 px-4 sm:px-6 w-full font-sans overflow-hidden flex flex-col items-center text-center justify-center z-10"
    >
        <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#10b981]/10 text-[#10b981] text-xs font-bold tracking-widest uppercase mb-8 border border-[#10b981]/20 shadow-sm backdrop-blur-md"
        >
            Fase de Co-creación
        </div>

        <h1
            class="text-5xl sm:text-6xl md:text-[5.5rem] font-sans font-extrabold leading-[1.05] tracking-tighter text-[#2D3748] mb-6 max-w-5xl mx-auto"
        >
            Construye con nosotros <br class="hidden md:block" />
            <span class="text-[#10b981] bg-clip-text"
                >la herramienta definitiva.</span
            >
        </h1>

        <p
            class="text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-snug font-medium tracking-tight"
        >
            Esto no es una venta, es una colaboración. Te damos acceso a un <strong
                >entorno seguro con datos ficticios</strong
            > para que experimentes y nos digas qué necesitas realmente.
        </p>
    </section>

    <section
        class="py-12 md:py-24 px-4 sm:px-6 w-full font-sans relative z-10 border-none bg-transparent"
    >
        <div class="max-w-6xl mx-auto relative border-none">
            <div
                class="hidden md:block absolute left-1/2 top-10 bottom-10 w-px bg-linear-to-b from-transparent via-[#b788f4]/50 to-transparent -translate-x-1/2 z-0"
            >
            </div>

            <div class="space-y-24 md:space-y-32">
                <div
                    class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 items-center"
                >
                    <div
                        class="text-center md:text-right order-2 md:order-1 flex flex-col items-center md:items-end relative"
                    >
                        <span
                            class="text-[6rem] md:text-[8rem] font-black leading-none tracking-tighter text-transparent bg-clip-text bg-linear-to-b from-[#b788f4]/30 to-transparent -mb-6 md:-mb-8 select-none z-0"
                            >01</span
                        >

                        <h3
                            class="relative z-10 text-3xl font-extrabold text-[#2D3748] mb-4 tracking-tight"
                        >
                            Nos conocemos.
                        </h3>
                        <p
                            class="relative z-10 text-slate-600 font-medium leading-relaxed text-lg max-w-md"
                        >
                            Nos acercamos a tu gabinete para explicarte el
                            proyecto en persona. Queremos conocer tus
                            frustraciones con tu sistema actual y ver cómo
                            trabajas.
                        </p>
                    </div>

                    <div
                        class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-12 h-12 bg-white/80 backdrop-blur-md border-4 border-[#b788f4]/20 rounded-full items-center justify-center z-20 shadow-[0_0_20px_rgba(183,136,244,0.3)]"
                    >
                        <div
                            class="w-3.5 h-3.5 bg-[#b788f4] rounded-full animate-pulse"
                        >
                        </div>
                    </div>

                    <div
                        class="order-1 md:order-2 w-full max-w-sm mx-auto md:max-w-none"
                    >
                        <div
                            class="relative rounded-[2.5rem] bg-linear-to-br from-white/60 to-white/10 backdrop-blur-2xl border border-white/60 shadow-[inset_0_1px_0_rgba(255,255,255,0.8),0_20px_50px_rgba(0,0,0,0.05)] p-8 h-72 flex items-center justify-center overflow-hidden group hover:-translate-y-1 transition-transform duration-500"
                        >
                            <img
                                src="/ilustraciones/reunion.svg"
                                alt="Ilustración de apretón de manos"
                                class="w-full h-full object-contain transform group-hover:scale-105 transition-transform duration-500 z-10 drop-shadow-sm"
                            />
                        </div>
                    </div>
                </div>

                <div
                    class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 items-center"
                >
                    <div class="order-1 w-full max-w-sm mx-auto md:max-w-none">
                        <div
                            class="relative rounded-[2.5rem] bg-linear-to-br from-white/60 to-white/10 backdrop-blur-2xl border border-white/60 shadow-[inset_0_1px_0_rgba(255,255,255,0.8),0_20px_50px_rgba(0,0,0,0.05)] p-8 h-72 flex items-center justify-center overflow-hidden group hover:-translate-y-1 transition-transform duration-500"
                        >
                            <img
                                src="/ilustraciones/preparacion.svg"
                                alt="Ilustración de entorno seguro Sandbox"
                                class="w-full h-full object-contain transform group-hover:scale-105 transition-transform duration-500 z-10 drop-shadow-sm"
                            />
                        </div>
                    </div>

                    <div
                        class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-12 h-12 bg-white/80 backdrop-blur-md border-4 border-[#b788f4]/20 rounded-full items-center justify-center z-20 shadow-[0_0_20px_rgba(183,136,244,0.3)]"
                    >
                        <div
                            class="w-3.5 h-3.5 bg-[#b788f4] rounded-full animate-pulse"
                        >
                        </div>
                    </div>

                    <div
                        class="text-center md:text-left order-2 flex flex-col items-center md:items-start relative"
                    >
                        <span
                            class="text-[6rem] md:text-[8rem] font-black leading-none tracking-tighter text-transparent bg-clip-text bg-linear-to-b from-[#b788f4]/30 to-transparent -mb-6 md:-mb-8 select-none z-0"
                            >02</span
                        >

                        <h3
                            class="relative z-10 text-3xl font-extrabold text-[#2D3748] mb-4 tracking-tight"
                        >
                            Tu propio "Lab".
                        </h3>
                        <p
                            class="relative z-10 text-slate-600 font-medium leading-relaxed text-lg max-w-md"
                        >
                            Te creamos una cuenta y la cargamos con <strong
                                >datos de prueba</strong
                            >. Un entorno seguro ("Sandbox") para que
                            experimentes, simules sesiones y pulses botones sin
                            miedo a romper nada.
                        </p>
                    </div>
                </div>

                <div
                    class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 items-center"
                >
                    <div
                        class="text-center md:text-right order-2 md:order-1 flex flex-col items-center md:items-end relative"
                    >
                        <span
                            class="text-[6rem] md:text-[8rem] font-black leading-none tracking-tighter text-transparent bg-clip-text bg-linear-to-b from-[#b788f4]/30 to-transparent -mb-6 md:-mb-8 select-none z-0"
                            >03</span
                        >

                        <h3
                            class="relative z-10 text-3xl font-extrabold text-[#2D3748] mb-4 tracking-tight"
                        >
                            Pide y se te dará.
                        </h3>
                        <p
                            class="relative z-10 text-slate-600 font-medium leading-relaxed text-lg max-w-md"
                        >
                            Tu misión no es trabajar, es criticar. ¿Falta un
                            botón? ¿Te sobra un menú? Nos lo cuentas a través de
                            una línea directa y nosotros lo construimos. Así de
                            simple.
                        </p>
                    </div>

                    <div
                        class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-12 h-12 bg-white/80 backdrop-blur-md border-4 border-[#b788f4]/20 rounded-full items-center justify-center z-20 shadow-[0_0_20px_rgba(183,136,244,0.3)]"
                    >
                        <div
                            class="w-3.5 h-3.5 bg-[#b788f4] rounded-full animate-pulse"
                        >
                        </div>
                    </div>

                    <div
                        class="order-1 md:order-2 w-full max-w-sm mx-auto md:max-w-none"
                    >
                        <div
                            class="relative rounded-[2.5rem] bg-linear-to-br from-white/60 to-white/10 backdrop-blur-2xl border border-white/60 shadow-[inset_0_1px_0_rgba(255,255,255,0.8),0_20px_50px_rgba(0,0,0,0.05)] p-8 h-72 flex items-center justify-center overflow-hidden group hover:-translate-y-1 transition-transform duration-500"
                        >
                            <img
                                src="/ilustraciones/feedback.svg"
                                alt="Ilustración de feedback loop"
                                class="w-full h-full object-contain transform group-hover:scale-105 transition-transform duration-500 z-10 drop-shadow-sm"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section
        class="py-16 md:py-32 px-4 sm:px-6 w-full relative z-10 bg-transparent"
    >
        <div class="max-w-4xl mx-auto">
            <div
                class="relative bg-linear-to-br from-white/70 to-white/30 backdrop-blur-3xl rounded-[3rem] overflow-hidden px-6 py-16 sm:px-16 sm:py-20 text-center border border-white/80 shadow-[inset_0_1px_0_rgba(255,255,255,1),0_40px_100px_rgba(16,185,129,0.15)]"
            >
                <div
                    class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-96 h-96 bg-[#10b981]/20 blur-[100px] rounded-full pointer-events-none"
                >
                </div>
                <div
                    class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/3 w-80 h-80 bg-indigo-500/15 blur-[100px] rounded-full pointer-events-none"
                >
                </div>

                <div class="relative z-10 space-y-8">
                    <h2
                        class="text-3xl md:text-5xl font-sans font-extrabold text-[#2D3748] tracking-tight leading-[1.1]"
                    >
                        ¿Aún no nos hemos pasado <br class="hidden md:block" /> por
                        tu gabinete?
                    </h2>

                    <p
                        class="text-lg text-slate-600 font-medium leading-relaxed max-w-2xl mx-auto"
                    >
                        Estamos visitando gabinetes en Dos Hermanas buscando
                        profesionales que quieran liderar el cambio. Si nos
                        hemos saltado el tuyo, avísanos y organizamos una visita
                        exprés.
                    </p>

                    <div
                        class="pt-6 flex flex-col sm:flex-row items-center justify-center gap-5"
                    >
                        <a
                            href="/contacto"
                            class="w-full sm:w-auto px-10 py-4 rounded-2xl bg-[#10b981] hover:bg-[#0ea572] hover:-translate-y-1 text-white font-extrabold text-center transition-all duration-300 shadow-[0_8px_32px_rgba(16,185,129,0.35)] hover:shadow-[0_12px_40px_rgba(16,185,129,0.5)] text-sm uppercase tracking-widest"
                        >
                            Solicitar Visita
                        </a>

                        <p
                            class="text-slate-500 font-bold text-sm bg-white/50 backdrop-blur-sm border border-slate-200 px-6 py-4 rounded-2xl"
                        >
                            ¿Ya te visitamos? Revisa tu email
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
