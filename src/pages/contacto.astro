---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto y Admisiones | Mindesk">
  <section
    class="min-h-[calc(100vh-80px)] flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden z-10"
  >
    <div
      class="max-w-6xl w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center relative z-10"
    >
      <div class="space-y-8 pt-0 text-center lg:text-left">
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#10b981]/10 text-[#10b981] text-xs font-bold tracking-widest uppercase border border-[#10b981]/20 shadow-sm backdrop-blur-md mx-auto lg:mx-0"
        >
          Fase de Admisión
        </div>

        <h1
          class="text-5xl md:text-6xl lg:text-[4.5rem] font-sans font-extrabold text-[#2D3748] leading-[1.05] tracking-tighter mb-6"
        >
          Solicita tu <br class="hidden lg:block" />
          <span class="text-[#10b981] bg-clip-text">acceso Beta.</span>
        </h1>

        <p class="text-xl text-slate-600 font-medium leading-relaxed">
          El acceso a Mindesk está actualmente restringido bajo invitación. Para
          garantizar el soporte personalizado, realizamos un <strong
            >proceso de validación</strong
          > con cada clínica.
        </p>
        <p class="text-lg text-slate-500 font-medium leading-relaxed mt-4">
          Si tu gabinete está en <strong>Dos Hermanas (Sevilla)</strong> y quieres
          liderar el cambio en la gestión clínica, completa la solicitud.
        </p>

        <div
          class="flex items-center justify-center lg:justify-start gap-4 pt-4"
        >
          <div class="text-sm font-bold text-slate-500">
            Únete a las <span class="text-[#10b981]">primeras clínicas</span><br
            />de la fase Beta.
          </div>
        </div>
      </div>

      <div class="relative w-full max-w-lg mx-auto lg:max-w-none">
        <div
          class="absolute -top-10 -right-10 w-64 h-64 bg-[#10b981]/15 blur-[80px] rounded-full pointer-events-none"
        >
        </div>
        <div
          class="absolute -bottom-10 -left-10 w-64 h-64 bg-indigo-500/10 blur-[80px] rounded-full pointer-events-none"
        >
        </div>

        <div
          class="relative bg-linear-to-br from-white/80 to-white/40 backdrop-blur-2xl rounded-[2.5rem] p-8 md:p-10 shadow-[inset_0_1px_0_rgba(255,255,255,0.9),0_20px_50px_rgba(0,0,0,0.05)] border border-white/80"
        >
          <form
            id="contact-form"
            action="https://formspree.io/f/xaqdwwpw"
            method="POST"
            class="space-y-5"
          >
            <input type="text" name="_gotcha" style="display:none" />

            <div>
              <label
                for="nombre"
                class="block text-[10px] font-extrabold text-slate-400 uppercase tracking-widest mb-1.5 ml-1"
                >Nombre del Responsable <span class="text-red-400">*</span
                ></label
              >
              <input
                type="text"
                name="nombre"
                id="nombre"
                required
                class="w-full rounded-2xl border-slate-200/60 bg-white/70 backdrop-blur-sm px-4 py-3.5 focus:border-[#10b981] focus:ring-2 focus:ring-[#10b981]/20 focus:bg-white text-slate-700 font-medium text-sm outline-none transition-all placeholder:text-slate-400 shadow-sm"
                placeholder="Tus nombres y apellidos"
              />
            </div>

            <div>
              <label
                for="gabinete"
                class="block text-[10px] font-extrabold text-slate-400 uppercase tracking-widest mb-1.5 ml-1"
                >Nombre del Centro <span class="text-red-400">*</span></label
              >
              <input
                type="text"
                name="gabinete"
                id="gabinete"
                required
                class="w-full rounded-2xl border-slate-200/60 bg-white/70 backdrop-blur-sm px-4 py-3.5 focus:border-[#10b981] focus:ring-2 focus:ring-[#10b981]/20 focus:bg-white text-slate-700 font-medium text-sm outline-none transition-all placeholder:text-slate-400 shadow-sm"
                placeholder="Ej. Clínica García"
              />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label
                  for="especialidad"
                  class="block text-[10px] font-extrabold text-slate-400 uppercase tracking-widest mb-1.5 ml-1"
                  >Especialidad <span class="text-red-400">*</span></label
                >
                <div class="relative">
                  <select
                    name="especialidad"
                    id="especialidad"
                    required
                    class="w-full appearance-none rounded-2xl border-slate-200/60 bg-white/70 backdrop-blur-sm px-4 py-3.5 focus:border-[#10b981] focus:ring-2 focus:ring-[#10b981]/20 focus:bg-white text-slate-700 font-medium text-sm outline-none transition-all shadow-sm"
                  >
                    <option value="" disabled selected class="text-slate-400"
                      >Seleccionar...</option
                    >
                    <option value="psicologia">Psicología</option>
                    <option value="logopedia">Logopedia</option>
                    <option value="pedagogia">Pedagogía</option>
                    <option value="multidisciplinar">Multidisciplinar</option>
                  </select>
                  <div
                    class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-400"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"></path></svg
                    >
                  </div>
                </div>
              </div>

              <div>
                <label
                  for="telefono"
                  class="block text-[10px] font-extrabold text-slate-400 uppercase tracking-widest mb-1.5 ml-1"
                  >Teléfono <span class="text-red-400">*</span></label
                >
                <input
                  type="tel"
                  name="telefono"
                  id="telefono"
                  required
                  class="w-full rounded-2xl border-slate-200/60 bg-white/70 backdrop-blur-sm px-4 py-3.5 focus:border-[#10b981] focus:ring-2 focus:ring-[#10b981]/20 focus:bg-white text-slate-700 font-medium text-sm outline-none transition-all placeholder:text-slate-400 shadow-sm"
                  placeholder="600 000 000"
                />
              </div>
            </div>

            <label
              class="bg-white/50 backdrop-blur-sm p-4 rounded-2xl border border-slate-100 flex items-start gap-3 mt-4 transition-colors hover:bg-white/70 group cursor-pointer"
            >
              <div class="flex h-5 items-center mt-0.5 shrink-0">
                <input
                  id="local"
                  name="local"
                  type="checkbox"
                  value="Sí, confirmado"
                  required
                  class="h-4 w-4 rounded border-slate-300 text-[#10b981] focus:ring-[#10b981] cursor-pointer accent-[#10b981]"
                />
              </div>
              <div
                class="text-sm leading-tight text-slate-600 font-medium group-hover:text-slate-800 transition-colors select-none"
              >
                Confirmo que dispongo de centro o consulta activa en <strong
                  class="text-[#2D3748]">Dos Hermanas (Sevilla)</strong
                >.
              </div>
            </label>

            <div class="pt-4">
              <button
                id="submit-btn"
                type="submit"
                class="w-full flex justify-center py-4 px-8 bg-[#10b981] text-white font-extrabold text-sm uppercase tracking-widest hover:bg-[#0ea572] hover:-translate-y-0.5 transition-all duration-300 shadow-[0_8px_32px_rgba(16,185,129,0.35)] hover:shadow-[0_12px_40px_rgba(16,185,129,0.5)] rounded-2xl"
              >
                Enviar Solicitud
              </button>
            </div>

            <p
              id="form-status"
              class="hidden text-sm text-center mt-3 font-bold px-4 py-2 rounded-xl"
            >
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById(
      "contact-form",
    ) as HTMLFormElement | null;
    const status = document.getElementById("form-status") as HTMLElement | null;
    const submitBtn = document.getElementById(
      "submit-btn",
    ) as HTMLButtonElement | null;

    if (form && status && submitBtn) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const originalText = submitBtn.innerText;
        submitBtn.innerText = "Enviando...";
        submitBtn.disabled = true;
        submitBtn.classList.add("opacity-75", "cursor-not-allowed");

        const data = new FormData(form);

        try {
          const response = await fetch(form.action, {
            method: form.method,
            body: data,
            headers: {
              Accept: "application/json",
            },
          });

          if (response.ok) {
            window.location.href = "/mensaje-enviado";
          } else {
            const data = await response.json();
            status.classList.remove("hidden", "bg-red-50", "text-red-500");
            status.classList.add(
              "bg-red-50",
              "text-red-500",
              "border",
              "border-red-100",
            );

            if (Object.prototype.hasOwnProperty.call(data, "errors")) {
              // @ts-ignore
              status.innerText = data["errors"]
                .map((error: { [x: string]: any; }) => error["message"])
                .join(", ");
            } else {
              status.innerText = "Hubo un problema. Inténtalo de nuevo.";
            }
            resetBtn();
          }
        } catch (error) {
          status.classList.remove("hidden", "bg-red-50", "text-red-500");
          status.classList.add(
            "bg-red-50",
            "text-red-500",
            "border",
            "border-red-100",
          );
          status.innerText = "Error de conexión. Verifica tu internet.";
          resetBtn();
        }

        function resetBtn() {
          if (submitBtn) {
            submitBtn.innerText = originalText;
            submitBtn.disabled = false;
            submitBtn.classList.remove("opacity-75", "cursor-not-allowed");
          }
        }
      });
    }
  </script>
</Layout>
