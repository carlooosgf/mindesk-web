---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mensaje Enviado | Mindesk">
    <section class="min-h-[calc(100vh-80px)] flex items-center justify-center relative overflow-hidden px-4 py-20">
        
        <!-- Glows de fondo -->
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#10b981]/10 blur-[120px] rounded-full pointer-events-none"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-[#b788f4]/8 blur-[100px] rounded-full pointer-events-none"></div>

        <!-- Contenedor principal -->
        <div class="relative z-10 max-w-2xl mx-auto">
          
          <!-- Card glassmorphism -->
          <div class="relative rounded-[2.5rem] bg-linear-to-br from-white/75 to-white/45 backdrop-blur-2xl border border-white/80 shadow-[inset_0_1px_0_rgba(255,255,255,0.95),0_40px_100px_rgba(16,185,129,0.12)] overflow-hidden px-8 py-16 sm:px-16 sm:py-20">
            
            <!-- Glow interno -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-64 h-64 bg-[#10b981]/8 blur-[80px] rounded-full pointer-events-none"></div>
            
            <!-- Contenido -->
            <div class="relative z-10 text-center space-y-8">
              
              <!-- Checkmark animado -->
              <div class="flex justify-center mb-4">
                <div class="relative">
                  <!-- Anillos de fondo -->
                  <div class="absolute inset-0 bg-[#10b981]/10 rounded-full animate-pulse"></div>
                  <div class="absolute -inset-2 bg-[#10b981]/5 rounded-full animate-pulse" style="animation-delay: 0.2s;"></div>
                  
                  <!-- Círculo principal -->
                  <div class="relative w-28 h-28 sm:w-32 sm:h-32 bg-linear-to-br from-[#10b981] to-[#059669] rounded-full flex items-center justify-center shadow-2xl shadow-[#10b981]/30">
                    <svg class="w-16 h-16 sm:w-20 sm:h-20 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 13l4 4L19 7"></path>
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Texto principal -->
              <div class="space-y-5">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#10b981]/10 text-[#10b981] text-xs font-extrabold tracking-widest uppercase border border-[#10b981]/20">
                  Solicitud recibida
                </div>
                
                <h1 class="text-4xl sm:text-5xl md:text-6xl font-sans font-extrabold tracking-tight text-[#2D3748] leading-[1.1]">
                  ¡Todo listo!
                </h1>
                
                <p class="text-lg sm:text-xl text-slate-600 font-medium leading-relaxed max-w-lg mx-auto">
                  Hemos recibido tu solicitud correctamente.<br class="hidden sm:block"/>
                  Uno de nuestros promotores contactará contigo en <strong class="text-[#2D3748]">menos de 24h</strong>.
                </p>
              </div>

              <!-- CTA -->
              <div class="pt-8 flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="/" 
                   class="w-full sm:w-auto px-8 py-4 rounded-full bg-[#10b981] text-white font-bold text-base transition-all duration-300 shadow-[0_0_45px_rgba(16,185,129,0.4)] hover:shadow-[0_0_65px_rgba(16,185,129,0.6)] hover:-translate-y-1">
                  Volver al inicio
                </a>
                
                <a href="/como-funciona" 
                   class="w-full sm:w-auto px-8 py-4 rounded-full bg-transparent text-slate-700 font-bold text-base border-2 border-slate-200 hover:bg-white hover:border-slate-300 transition-all duration-300">
                  Ver cómo funciona
                </a>
              </div>

              <!-- Información adicional -->
              <div class="pt-8 flex items-center justify-center gap-4 text-xs text-slate-400 font-medium">
                <div class="flex items-center gap-1.5">
                  <svg class="w-4 h-4 text-[#10b981]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  Respuesta en 24h
                </div>
                <span class="text-slate-300">·</span>
                <div class="flex items-center gap-1.5">
                  <svg class="w-4 h-4 text-[#10b981]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                  Sin compromiso
                </div>
              </div>

            </div>
          </div>

        </div>
    </section>
</Layout>