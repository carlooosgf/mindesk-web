---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mensaje Enviado | Mindesk">
    <section class="min-h-[calc(100vh-80px)] flex items-center justify-center bg-brand-bg relative overflow-hidden px-4">
        
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-brand-primary/10 blur-[100px] rounded-full pointer-events-none"></div>

        <div class="relative z-10 text-center space-y-8 max-w-lg mx-auto">
            
            <div class="flex justify-center">
                <div class="w-24 h-24 bg-white rounded-full flex items-center justify-center shadow-lg shadow-brand-primary/10">
                    <svg class="w-12 h-12 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
            </div>

            <div class="space-y-4">
                <h1 class="text-4xl font-serif font-medium text-brand-text">¡Recibido!</h1>
                <p class="text-slate-600 text-lg leading-relaxed">
                    Hemos recibido tu solicitud correctamente. Uno de nuestros promotores contactará contigo en menos de 24h.
                </p>
            </div>

            <div class="pt-4">
                <a href="/" class="inline-block text-brand-primary font-bold hover:text-brand-text transition-colors border-b-2 border-transparent hover:border-brand-text pb-1">
                    Volver al inicio
                </a>
            </div>

        </div>
    </section>
</Layout>